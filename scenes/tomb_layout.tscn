[node name="GuardRevealSequence" type="Node" parent="Rooms/01_TerracottaWorkshop/WorkshopQuestProps/TerracottaWorkTarget" unique_id=192109149]
script = ExtResource("Script_dialogue_sequence")
required_objective_id = "continue_modeling"
dialogue_lines = PackedStringArray("Meșteșugar: Încă puțin. Lutul trebuie să țină linia picioarelor.", "Gardianul 1: Mă uit la poarta aceea de bronz și mă gândesc că n-o să mai vedem soarele de mâine. S-a dat ordinul de sigilare.", "Gardianul 2: Am auzit... Până se crapă de ziuă, sigilează totul. Mai mult de jumătate din sectoare sunt deja închise, printre care și al nostru.", "Gardianul 1: Era de așteptat. Un mormânt ca ăsta nu se lasă descuiat. Dar nu credeam că ne vor încuia și pe noi în el.", "Gardianul 2: Toți rămân sub munte. Nimic nu trebuie să părăsească aceste coridoare.", "Gardianul 1: Și dacă vreunul încearcă să iasă?", "Gardianul 2: Avem ordin clar: oricine se apropie de poarta principală trebuie doborât.", "Meșteșugar: Nu pot să cred. Ne vor îngropa aici... Nu pot rămâne.", "Meșteșugar: Poate Liang mă poate ajuta.")
dialogue_line_duration = 5.8
objective_after_id = "find_liang"
objective_after_text = "Găsește-l pe Liang în atelierul secundar."
prompt_text = "Continuă modelarea"

