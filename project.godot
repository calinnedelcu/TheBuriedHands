; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TheBuriedHands"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://audio/default_bus_layout.tres"

[autoload]

NoiseBus="*res://Scripts/noise_bus.gd"
Objectives="*res://Scripts/objectives.gd"
GameEvents="*res://Scripts/game_events.gd"
SettingsManager="*res://Scripts/settings_manager.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/Tripo3d_Godot_Bridge/plugin.cfg")

[file_customization]

folder_colors={
"res://Scripts/": "yellow",
"res://TripoModels/": "red"
}

